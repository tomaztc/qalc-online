+#elif defined(QALC_FIBER_THREADS)
+
+// ---------------------------------------------------------------------------
+// Cooperative, single-threaded reimplementation of Thread using Emscripten
+// fibers. libqalculate's threads are a strict producer/consumer pair: a caller
+// pushes bytes with write() and busy-waits on a flag, while the worker's run()
+// loop blocks in read() until data arrives, performs work to completion, then
+// loops back to block again. There is never true parallelism required -- the
+// caller does nothing useful until the worker finishes. So we model each worker
+// as its own fiber: write() appends to a byte queue and swaps into the worker,
+// which runs until it next blocks on an empty read() and swaps back. Because a
+// full calculation contains no intervening read(), it runs to completion during
+// the write() that delivers its final argument, so the caller's subsequent
+// busy-wait simply observes b_busy == false. No pthreads, no SharedArrayBuffer,
+// no special COOP/COEP headers -- the result is a plain static wasm module.
+// ---------------------------------------------------------------------------
+
+#include <emscripten/fiber.h>
+#include <deque>
+
+// C stack per worker fiber. Calculation recursion (MathStructure) can be deep,
+// so this is generous. Allocated lazily on first start(), only for threads used.
+#define QALC_FIBER_CSTACK (24 * 1024 * 1024)
+// Asyncify stack: only needs to cover the shallow call chain at a swap point
+// (always inside read()/run()), never a mid-calculation frame.
+#define QALC_FIBER_ASTACK (256 * 1024)
+
+struct FiberThreadImpl {
+	emscripten_fiber_t fiber;
+	emscripten_fiber_t *caller; // fiber to resume when this worker blocks
+	std::deque<char> queue;
+	char *cstack;
+	char *astack;
+	bool inited;
+	FiberThreadImpl() : caller(NULL), cstack(NULL), astack(NULL), inited(false) {}
+};
+
+// The fiber currently executing. Set before every swap so a blocked worker
+// knows who resumed it. Initialised to the main/driver context by
+// qalc_fiber_set_main() at startup.
+static emscripten_fiber_t *g_qalc_current_fiber = NULL;
+
+void qalc_fiber_set_main(emscripten_fiber_t *main_fiber) {
+	g_qalc_current_fiber = main_fiber;
+}
+
+static void qalc_fiber_swap(emscripten_fiber_t *target) {
+	emscripten_fiber_t *from = g_qalc_current_fiber;
+	g_qalc_current_fiber = target;
+	emscripten_fiber_swap(from, target);
+}
+
+void qalc_fiber_swap_to(emscripten_fiber_t *target_fiber) {
+	qalc_fiber_swap(target_fiber);
+}
+
+Thread::Thread() : running(false), m_fiber(NULL) {
+	m_fiber = (void *) new FiberThreadImpl();
+}
+
+Thread::~Thread() {
+	cancel();
+	FiberThreadImpl *impl = (FiberThreadImpl *) m_fiber;
+	if(impl) {
+		free(impl->cstack);
+		free(impl->astack);
+		delete impl;
+	}
+}
+
+void Thread::enableAsynchronousCancel() {}
+
+void Thread::fiber_trampoline(void *data) {
+	Thread *thread = (Thread *) data;
+	thread->run();
+	// run() loops forever in practice; if it ever returns, park by resuming
+	// the caller and marking not running.
+	thread->running = false;
+	FiberThreadImpl *impl = (FiberThreadImpl *) thread->m_fiber;
+	qalc_fiber_swap(impl->caller);
+}
+
+void Thread::fiber_write(const char *p, size_t n) {
+	FiberThreadImpl *impl = (FiberThreadImpl *) m_fiber;
+	for(size_t i = 0; i < n; i++) impl->queue.push_back(p[i]);
+	impl->caller = g_qalc_current_fiber;
+	qalc_fiber_swap(&impl->fiber);
+}
+
+bool Thread::fiber_read(char *p, size_t n) {
+	FiberThreadImpl *impl = (FiberThreadImpl *) m_fiber;
+	while(impl->queue.size() < n) {
+		if(!running) return false;
+		// Block: hand control back to whoever last wrote/started us.
+		qalc_fiber_swap(impl->caller);
+	}
+	for(size_t i = 0; i < n; i++) { p[i] = impl->queue.front(); impl->queue.pop_front(); }
+	return true;
+}
+
+bool Thread::start() {
+	if(running) return true;
+	FiberThreadImpl *impl = (FiberThreadImpl *) m_fiber;
+	if(!impl->inited) {
+		impl->cstack = (char *) malloc(QALC_FIBER_CSTACK);
+		impl->astack = (char *) malloc(QALC_FIBER_ASTACK);
+		emscripten_fiber_init(&impl->fiber, &Thread::fiber_trampoline, this,
+			impl->cstack, QALC_FIBER_CSTACK, impl->astack, QALC_FIBER_ASTACK);
+		impl->inited = true;
+	}
+	running = true;
+	impl->caller = g_qalc_current_fiber;
+	// Run the worker until it first blocks on an empty read().
+	qalc_fiber_swap(&impl->fiber);
+	return running;
+}
+
+bool Thread::cancel() {
+	if(!running) return true;
+	running = false;
+	FiberThreadImpl *impl = (FiberThreadImpl *) m_fiber;
+	if(impl) impl->queue.clear();
+	return true;
+}
+
 #else
 
 Thread::Thread() : running(false), m_pipe_r(NULL), m_pipe_w(NULL) {
