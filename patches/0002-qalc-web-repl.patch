+#ifdef QALC_WEB
+// Side-effect-free evaluation for the live "as you type" preview. Uses the
+// current global evaluation/print options (so it honours every "set" the user
+// has made) but does NOT update ans, history, or the saved result -- unlike the
+// real REPL path in execute_expression(). Returns a freshly computed terminal
+// result string. Empty input or a pure command/assignment yields an empty
+// string. Runs fully synchronously (calculateAndPrint uses a polled timeout,
+// not the worker thread).
+static string g_web_preview;
+const char *qalc_web_preview_expression(const char *expr, int timeout_ms) {
+	g_web_preview.clear();
+	if(!expr) return g_web_preview.c_str();
+	string str = expr;
+	remove_blank_ends(str);
+	if(str.empty()) return g_web_preview.c_str();
+	// Skip explicit commands and things the preview shouldn't run.
+	if(str[0] == '/' || str[0] == '#') return g_web_preview.c_str();
+	CALCULATOR->clearMessages();
+	PrintOptions po = printops;
+	po.is_approximate = NULL;
+	g_web_preview = CALCULATOR->calculateAndPrint(str, timeout_ms, evalops, po,
+		dual_fraction < 0 ? AUTOMATIC_FRACTION_AUTO : (dual_fraction > 0 ? AUTOMATIC_FRACTION_DUAL : AUTOMATIC_FRACTION_OFF),
+		dual_approximation < 0 ? AUTOMATIC_APPROXIMATION_AUTO : (dual_approximation > 0 ? AUTOMATIC_APPROXIMATION_DUAL : AUTOMATIC_APPROXIMATION_OFF),
+		NULL, -1, NULL, false, colorize ? colorize : 0, TAG_TYPE_TERMINAL);
+	return g_web_preview.c_str();
+}
+#endif
